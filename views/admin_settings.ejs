<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Settings - Spectrum 4 Voting System</title>
  <link rel="icon" href="/favicon.ico">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <%- include('partials/admin_header') %>

  <div class="container">
    <div class="page-header">
      <h1>Admin Settings</h1>
      <a href="/admin/dashboard" class="btn btn-secondary">Back to Dashboard</a>
    </div>

    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="card">
      <h2>Change Administrator Password</h2>
      <p class="text-muted">Update the password used to access the admin panel.</p>

      <form method="POST" action="/admin/settings/password" class="form">
        <input type="hidden" name="_csrf" value="<%= csrfToken() %>">
        
        <div class="form-group">
          <label for="current_password">Current Password</label>
          <input type="password" id="current_password" name="current_password" required>
        </div>

        <div class="form-group">
          <label for="new_password">New Password</label>
          <input type="password" id="new_password" name="new_password" required minlength="8">
          <small class="form-help">Minimum 8 characters</small>
        </div>

        <div class="form-group">
          <label for="confirm_password">Confirm New Password</label>
          <input type="password" id="confirm_password" name="confirm_password" required minlength="8">
        </div>

        <button type="submit" class="btn btn-primary">Update Password</button>
      </form>
    </div>

    <div class="card">
      <h2>Property Manager</h2>
      <p class="text-muted">Configure the Property Manager recipient for vote completion results emails.</p>

      <form method="POST" action="/admin/settings/property-manager" class="form">
        <input type="hidden" name="_csrf" value="<%= csrfToken() %>">

        <div class="form-group">
          <label for="property_manager_name">Property Manager Name</label>
          <input type="text" id="property_manager_name" name="property_manager_name" value="<%= property_manager_name || '' %>">
        </div>

        <div class="form-group">
          <label for="property_manager_email">Property Manager Email *</label>
          <input type="email" id="property_manager_email" name="property_manager_email" required value="<%= property_manager_email || '' %>">
        </div>

        <button type="submit" class="btn btn-primary">Update Property Manager</button>
      </form>
    </div>

    <div class="card">
      <h2>Email Configuration</h2>
      <p class="text-muted">Test the email configuration for sending voting links.</p>

      <form method="POST" action="/admin/settings/test-email" class="form">
        <input type="hidden" name="_csrf" value="<%= csrfToken() %>">
        <button type="submit" class="btn btn-secondary">Test Email Configuration</button>
      </form>
    </div>

    <div class="card">
      <h2>Email Trigger (IMAP Inbox)</h2>
      <p class="text-muted">When configured, an authorized sender can create a new vote by emailing this inbox. The email subject becomes the motion title and the body becomes the description. Voting links are sent automatically to all council members.</p>

      <form method="POST" action="/admin/settings/email-trigger" class="form">
        <input type="hidden" name="_csrf" value="<%= csrfToken() %>">

        <div class="form-group">
          <label for="imap_host">IMAP Host</label>
          <input type="text" id="imap_host" name="imap_host" value="<%= imap_host || '' %>" placeholder="imap.gmail.com">
        </div>

        <div class="form-group">
          <label for="imap_port">IMAP Port</label>
          <input type="number" id="imap_port" name="imap_port" value="<%= imap_port || '993' %>" placeholder="993">
        </div>

        <div class="form-group">
          <label for="imap_user">IMAP Username / Email</label>
          <input type="email" id="imap_user" name="imap_user" value="<%= imap_user || '' %>" placeholder="votes@example.com">
        </div>

        <div class="form-group">
          <label for="imap_password">IMAP Password / App Password</label>
          <input type="password" id="imap_password" name="imap_password" placeholder="<%= imap_password_set ? '(saved — leave blank to keep)' : 'Enter password' %>">
          <% if (imap_password_set) { %>
            <small class="form-help">A password is currently saved. Leave blank to keep it.</small>
          <% } %>
        </div>

        <div class="form-group">
          <label for="imap_authorized_senders">Authorized Senders (comma-separated emails)</label>
          <input type="text" id="imap_authorized_senders" name="imap_authorized_senders" value="<%= imap_authorized_senders || '' %>" placeholder="manager@example.com, president@example.com">
          <small class="form-help">Only emails from these addresses will create votes. Leave empty to allow any sender.</small>
        </div>

        <div class="form-group">
          <label for="imap_default_deadline_hours">Default Voting Window (hours)</label>
          <input type="number" id="imap_default_deadline_hours" name="imap_default_deadline_hours" value="<%= imap_default_deadline_hours || '48' %>" min="1" max="720">
        </div>

        <div class="form-group">
          <label for="imap_poll_interval_ms">Poll Interval (milliseconds)</label>
          <input type="number" id="imap_poll_interval_ms" name="imap_poll_interval_ms" value="<%= imap_poll_interval_ms || '60000' %>" min="10000">
          <small class="form-help">How often to check the inbox. Default: 60000 (1 minute). Requires server restart to take effect on a running instance.</small>
        </div>

        <button type="submit" class="btn btn-primary">Save Email Trigger Settings</button>
      </form>

      <form method="POST" action="/admin/settings/test-email-trigger" class="form" style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--color-border, #e5e7eb);">
        <input type="hidden" name="_csrf" value="<%= csrfToken() %>">
        <button type="submit" class="btn btn-secondary">Test Polling Now</button>
        <small class="form-help" style="display: block; margin-top: 0.4rem;">Runs one poll cycle immediately and reports how many unseen emails were found and processed.</small>
      </form>
    </div>

    <div class="card">
      <h2>WhatsApp Notifications (OpenWA)</h2>
      <p class="text-muted">When configured, council members with a WhatsApp number on their profile will receive voting links via WhatsApp in addition to email.</p>

      <form method="POST" action="/admin/settings/whatsapp" class="form">
        <input type="hidden" name="_csrf" value="<%= csrfToken() %>">

        <div class="form-group">
          <label for="openwa_url">OpenWA Server URL</label>
          <input type="text" id="openwa_url" name="openwa_url" value="<%= openwa_url || '' %>" placeholder="https://openwa.example.com">
        </div>

        <div class="form-group">
          <label for="openwa_api_key">OpenWA API Key</label>
          <input type="password" id="openwa_api_key" name="openwa_api_key" placeholder="<%= openwa_api_key_set ? '(saved — leave blank to keep)' : 'Enter API key' %>">
          <% if (openwa_api_key_set) { %>
            <small class="form-help">An API key is currently saved. Leave blank to keep it.</small>
          <% } %>
        </div>

        <div class="form-group">
          <label for="openwa_session_id">OpenWA Session ID</label>
          <input type="text" id="openwa_session_id" name="openwa_session_id" value="<%= openwa_session_id || '' %>" placeholder="default">
        </div>

        <button type="submit" class="btn btn-primary">Save WhatsApp Settings</button>
      </form>
    </div>

    <div class="card">
      <h2>System Information</h2>
      <div class="detail-row">
        <strong>Application:</strong>
        <p>Spectrum 4 Voting System</p>
      </div>
      <div class="detail-row">
        <strong>Environment:</strong>
        <p><%= process.env.NODE_ENV || 'development' %></p>
      </div>
      <div class="detail-row">
        <strong>Database:</strong>
        <p><%= dbPath || 'SQLite' %></p>
      </div>
    </div>
  </div>
</body>
</html>
